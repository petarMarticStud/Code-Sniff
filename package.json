{
  "name": "code-sniff",
  "version": "1.0.0",
  "scripts": {
    "install:all": "npm install && npm install --prefix client && npm install --prefix server",
    "dev": "concurrently \"npm run dev --prefix client\" \"node server/index.js\"",
    "start:unified": "cd client && npm run build && cd ../server && node index.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "groq-sdk": "^1.1.2",
    "openai": "^6.33.0",
    "react-diff-viewer-continued": "^4.2.0",
    "react-syntax-highlighter": "^16.1.1",
    "tree-sitter": "^0.21.1",
    "tree-sitter-java": "^0.23.5"
  }
}
